{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "node": "20"
  },
  "steps": {
    "build-frontend": {
      "inputs": [{ "step": "packages:mise" }],
      "commands": [
        { "cmd": "npm --prefix frontend ci" },
        { "cmd": "npm --prefix frontend run build" }
      ],
      "deployOutputs": [{ "include": ["frontend/dist"] }]
    }
  }
}
